---
interface Props {
  song: {
    id: string;
    title: string;
    album: string | null;
    year: number;
    type: string;
    features: string[];
    mood: string[];
    cover_image?: string | null;
  };
}

const { song } = Astro.props;
const base = import.meta.env.BASE_URL;

function getTypeLabel(type: string): string {
  const labels: Record<string, string> = {
    album_track: 'Album Track',
    mixtape_track: 'Mixtape',
    single: 'Single',
    feature: 'Feature',
  };
  return labels[type] || type;
}

const coverSrc = song.cover_image
  ? `${base.replace(/\/$/, '')}/${song.cover_image.replace(/^\//, '')}`
  : `${base.replace(/\/$/, '')}/images/covers/singles-features.png`;
const typeLabel = getTypeLabel(song.type);
---

<a
  href={`${base.replace(/\/$/, '')}/songs/${song.id}/`}
  class="song-card"
  data-song={song.id}
  data-type={song.type}
  data-moods={song.mood.join(',')}
  data-album={song.album || 'Singles & Features'}
  data-year={String(song.year)}
  data-title={song.title}
>
  <div class="song-card__cover card-cover-wrap">
    <img class="song-card-image" src={coverSrc} alt={song.title} loading="lazy" crossorigin="anonymous" />
    <div class="card-title-overlay">{song.title}</div>
    <div class="song-card__badge">
      <span class={`type-badge type-badge--${song.type}`}>{typeLabel}</span>
    </div>
  </div>
  <div class="song-card__body song-card-body">
    <h3 class="song-card__title song-card-title">{song.title}</h3>
    <div class="song-card__meta song-card-meta">
      <span>{song.album || 'Single / Feature'}</span>
      <span class="song-card__meta-sep"></span>
      <span>{song.year}</span>
    </div>
    {song.features.length > 0 && (
      <p class="song-card__features">
        feat. <span>{song.features.join(', ')}</span>
      </p>
    )}
    <div class="song-card__moods song-card-moods">
      {song.mood.map((m) => (
        <span class={`mood-tag mood-tag--${m} mood-pill`}>{m}</span>
      ))}
    </div>
  </div>
</a>

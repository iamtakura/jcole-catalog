---
import Base from '../../layouts/Base.astro';
import songs from '../../data/songs.json';

export function getStaticPaths() {
  return songs.map((song: any) => ({
    params: { id: song.id },
    props: { song },
  }));
}

const { song } = Astro.props;
const base = import.meta.env.BASE_URL;

function getTypeLabel(type: string): string {
  const labels: Record<string, string> = {
    album_track: 'Album Track',
    mixtape_track: 'Mixtape',
    single: 'Single',
    feature: 'Feature',
  };
  return labels[type] || type;
}

const coverSrc = song.cover_image
  ? `${base.replace(/\/$/, '')}/${song.cover_image.replace(/^\//, '')}`
  : `${base.replace(/\/$/, '')}/images/covers/singles-features.png`;
const typeLabel = getTypeLabel(song.type);

// Find prev/next songs
const currentIndex = songs.findIndex((s: any) => s.id === song.id);
const prevSong = currentIndex > 0 ? songs[currentIndex - 1] : null;
const nextSong = currentIndex < songs.length - 1 ? songs[currentIndex + 1] : null;
---

<Base title={song.title} description={song.breakdown?.summary || `${song.title} by J. Cole`} namespace="song">
  <div class="song-detail">
    <!-- Spotify-style layered hero -->
    <div class="song-hero song-detail__hero">
      <!-- Blurred atmospheric background -->
      <div class="hero-bg" style={`background-image: url('${coverSrc}')`}></div>
      
      <!-- Dark overlay -->
      <div class="hero-overlay"></div>
      
      <!-- Actual cover art + song info -->
      <div class="hero-content">
        <img class="hero-cover song-detail__hero-img" src={coverSrc} alt={song.title} crossorigin="anonymous" />
        <div class="hero-info">
          <h1 class="song-detail__title">{song.title}</h1>
          <p class="song-detail__album-link">{song.album || 'Single / Feature'}</p>

          <!-- Meta Grid -->
          <div class="song-detail__meta-grid">
            <div class="song-detail__meta-item">
              <span class="song-detail__meta-label">Year</span>
              <span class="song-detail__meta-value">{song.year}</span>
            </div>
            <div class="song-detail__meta-item">
              <span class="song-detail__meta-label">Type</span>
              <span class="song-detail__meta-value">
                <span class={`type-badge type-badge--${song.type}`}>{typeLabel}</span>
              </span>
            </div>
            {song.producers && song.producers.length > 0 && (
              <div class="song-detail__meta-item">
                <span class="song-detail__meta-label">Producers</span>
                <span class="song-detail__meta-value">{song.producers.join(', ')}</span>
              </div>
            )}
            {song.features && song.features.length > 0 && (
              <div class="song-detail__meta-item">
                <span class="song-detail__meta-label">Features</span>
                <span class="song-detail__meta-value">{song.features.join(', ')}</span>
              </div>
            )}
          </div>

          <!-- Mood Tags -->
          {song.mood && song.mood.length > 0 && (
            <div class="song-detail__tags">
              {song.mood.map((m: string) => (
                <span class={`mood-tag mood-tag--${m}`}>{m}</span>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="song-detail__content">
      <!-- Back button -->
      <a href={`${base.replace(/\/$/, '')}/`} class="back-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Back to Catalog
      </a>

      <!-- Breakdown -->
      {song.breakdown && (
        <div class="breakdown">
          {song.breakdown.summary && (
            <div class="breakdown__section">
              <div class="breakdown__label">Summary</div>
              <p class="breakdown__summary">{song.breakdown.summary}</p>
            </div>
          )}

          {song.breakdown.themes && song.breakdown.themes.length > 0 && (
            <div class="breakdown__section">
              <div class="breakdown__label">Themes</div>
              <div class="breakdown__themes">
                {song.breakdown.themes.map((theme: string) => (
                  <span class="breakdown__theme-tag">{theme}</span>
                ))}
              </div>
            </div>
          )}

          {song.breakdown.story && (
            <div class="breakdown__section">
              <div class="breakdown__label">The Story</div>
              <p class="breakdown__text">{song.breakdown.story}</p>
            </div>
          )}

          {song.breakdown.inspiration && (
            <div class="breakdown__section">
              <div class="breakdown__label">Inspiration</div>
              <p class="breakdown__text">{song.breakdown.inspiration}</p>
            </div>
          )}
        </div>
      )}

      <!-- Song Navigation -->
      <nav class="song-nav">
        {prevSong ? (
          <a href={`${base.replace(/\/$/, '')}/songs/${prevSong.id}/`} class="song-nav__link">
            <span class="song-nav__link-label">← Previous</span>
            <span class="song-nav__link-title">{prevSong.title}</span>
          </a>
        ) : <div></div>}
        {nextSong ? (
          <a href={`${base.replace(/\/$/, '')}/songs/${nextSong.id}/`} class="song-nav__link song-nav__link--next">
            <span class="song-nav__link-label">Next →</span>
            <span class="song-nav__link-title">{nextSong.title}</span>
          </a>
        ) : <div></div>}
      </nav>
    </div>
  </div>
</Base>

<style>
  .song-hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    filter: blur(60px) brightness(0.25) saturate(1.4);
    transform: scale(1.1);
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 0%, #080808 100%);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: flex-end;
    gap: 2.5rem;
    padding: 3rem;
    width: 100%;
  }

  .hero-cover {
    width: 220px;
    height: 220px;
    object-fit: cover;
    border-radius: 4px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.6);
    flex-shrink: 0;
  }

  /* Override content negative margin to prevent overlap with Spotify-style hero details */
  .song-detail__content {
    margin-top: 0 !important;
    padding-top: var(--space-xl);
  }

  /* Mobile */
  @media (max-width: 640px) {
    .hero-content {
      flex-direction: column;
      align-items: flex-start;
      padding: 1.5rem;
    }
    .hero-cover {
      width: 160px;
      height: 160px;
    }
  }
</style>

<script>
  import { getPaletteSync } from 'colorthief';

  const cover = document.querySelector('.hero-cover') as HTMLImageElement;
  
  if (cover) {
    function applyPalette() {
      try {
        const palette = getPaletteSync(cover, { colorCount: 3 });
        if (palette && palette.length > 0) {
          const dominant = palette[0].array();
          const secondary = palette[1] ? palette[1].array() : palette[0].array();

          const r1 = dominant[0], g1 = dominant[1], b1 = dominant[2];
          const r2 = secondary[0], g2 = secondary[1], b2 = secondary[2];

          document.documentElement.style.setProperty('--accent', `rgb(${r1},${g1},${b1})`);
          document.documentElement.style.setProperty('--accent-secondary', `rgb(${r2},${g2},${b2})`);
          document.documentElement.style.setProperty('--hero-glow', `rgba(${r1},${g1},${b1},0.15)`);

          // Apply glow to cover image
          const heroCover = document.querySelector('.hero-cover') as HTMLElement;
          if (heroCover) {
            heroCover.style.boxShadow = `0 20px 60px rgba(${r1},${g1},${b1},0.4)`;
          }

          // Apply gradient tint to hero background overlay
          const heroOverlay = document.querySelector('.hero-overlay') as HTMLElement;
          if (heroOverlay) {
            heroOverlay.style.background = `linear-gradient(to bottom, rgba(${r1},${g1},${b1},0.08) 0%, #080808 70%)`;
          }

          // Apply accent to mood tags border color
          document.querySelectorAll('.mood-tag').forEach(tag => {
            (tag as HTMLElement).style.borderColor = `rgba(${r1},${g1},${b1},0.5)`;
            (tag as HTMLElement).style.color = `rgb(${r1},${g1},${b1})`;
          });

          // Apply to section headings like SUMMARY, THEMES etc
          document.querySelectorAll('.breakdown__label').forEach(el => {
            (el as HTMLElement).style.color = `rgb(${r1},${g1},${b1})`;
          });
        }
      } catch (e) {
        /* ignore */
      }
    }

    if (cover.complete) {
      applyPalette();
    } else {
      cover.addEventListener('load', applyPalette);
    }
  }
</script>
